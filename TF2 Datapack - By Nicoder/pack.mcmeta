{
    "pack": {
        "min_format": [101, 0],
        "max_format": [110, 0],
        "description": "Team Fortress 2, recreated in Minecraft"
    },
    "filter": {
        "block": [
            {
                "namespace": "^minecraft$",
                "path": "recipe/.*"
            },
            {
                "namespace": "^minecraft$",
                "path": "advancement/.*"
            }
        ]
    }
}